{
  "compilerOptions": {
    "lib": ["dom", "es2020"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noUnusedLocals": true,
    "rootDir": "src",
    "strict": true,
    "target": "es2020",
    "removeComments": true,
    "outDir": "dist",
    "noEmit": false,
    "declaration": false,
    "types": []
  },
  "include": ["src"]
}
