{
  "compilerOptions": {
    "lib": ["dom", "es2015", "scripthost"],
    "module": "es2015",
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "rootDir": "src",
    "strict": true,
    "target": "es2020",
    "removeComments": true,
    "outDir": "dist",
    "baseUrl": ".",
    "noEmit": false,
    "declaration": false
  },
  "include": ["src"]
}
